postgres-shell:
    psql -h localhost -d etl_analytics

create-databases:
    @echo "[PostgreSQL] Creating databases..."
    @createdb -h localhost airflow_metadata 2>/dev/null || echo "airflow_metadata already exists"
    @createdb -h localhost etl_analytics 2>/dev/null || echo "etl_analytics already exists"
    @echo "[OK] Databases ready"

create-postgres-schemas:
    @echo "[PostgreSQL] Creating PostgreSQL table schemas..."
    psql -h localhost -d etl_analytics -f infrastructure/postgres-schemas/create_gold_tables.sql
    @echo "[OK] Schemas created"

