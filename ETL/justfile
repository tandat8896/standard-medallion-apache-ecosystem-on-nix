verify-postgres:
    @echo "[VERIFY] Verifying PostgreSQL data..."
    @echo ""
    @echo "Table: kpi_daily_revenue"
    @psql -h localhost -d etl_analytics -c "SELECT COUNT(*), MIN(dt), MAX(dt) FROM kpi_daily_revenue;" 2>/dev/null || echo "  [WARN] No data or table doesn't exist"
    @echo ""
    @echo "Table: kpi_user_retention"
    @psql -h localhost -d etl_analytics -c "SELECT COUNT(*), MIN(dt), MAX(dt) FROM kpi_user_retention;" 2>/dev/null || echo "  [WARN] No data or table doesn't exist"
    @echo ""
    @echo "Table: kpi_inventory_turnover"
    @psql -h localhost -d etl_analytics -c "SELECT COUNT(*), MIN(dt), MAX(dt) FROM kpi_inventory_turnover;" 2>/dev/null || echo "  [WARN] No data or table doesn't exist"
    @echo ""
    @echo "Table: kpi_iot_anomaly_summary"
    @psql -h localhost -d etl_analytics -c "SELECT COUNT(*), MIN(dt), MAX(dt) FROM kpi_iot_anomaly_summary;" 2>/dev/null || echo "  [WARN] No data or table doesn't exist"

# ============================================================================
# STATUS & LOGS
# ============================================================================

status:
    @echo "[STATUS] Service Status:"
    @echo ""
    @if pgrep -f krb5kdc > /dev/null; then echo "KDC:       [OK] RUNNING"; else echo "KDC:       [FAIL] STOPPED"; fi
    @if pgrep -f QuorumPeerMain > /dev/null; then echo "ZooKeeper: [OK] RUNNING"; else echo "ZooKeeper: [FAIL] STOPPED"; fi
    @if pgrep -f 'kafka.Kafka' > /dev/null; then echo "Kafka:     [OK] RUNNING"; else echo "Kafka:     [FAIL] STOPPED"; fi
    @if pgrep -f 'org.apache.flink' > /dev/null; then echo "Flink:     [OK] RUNNING"; else echo "Flink:     [FAIL] STOPPED"; fi
    @if pgrep -f 'org.apache.spark.deploy.master.Master' > /dev/null; then echo "Spark:     [OK] RUNNING"; else echo "Spark:     [FAIL] STOPPED"; fi
    @if pg_ctl status -D infrastructure/pg_db > /dev/null 2>&1; then echo "Postgres:  [OK] RUNNING"; else echo "Postgres:  [FAIL] STOPPED"; fi

logs SERVICE:
    @tail -50 infrastructure/{{SERVICE}}-data/logs/*.log 2>/dev/null || tail -50 infrastructure/{{SERVICE}}-data/*.log 2>/dev/null

# ============================================================================
# CLEANUP
# ============================================================================

clean-bronze:
    @echo "[WARN] Cleaning Bronze layer..."
    @read -p "Are you sure? [y/N] " -n 1 -r; \
    if [[ $$REPLY =~ ^[Yy]$$ ]]; then \
        rm -rf {{justfile_directory()}}/../datalake/bronze/*; \
        echo "[OK] Bronze layer cleaned"; \
    fi

clean-all-data:
    @echo "[WARN] This will delete ALL data (Bronze/Silver/Gold/Checkpoints)"
    @read -p "Are you sure? [y/N] " -n 1 -r; \
    if [[ $$REPLY =~ ^[Yy]$$ ]]; then \
        rm -rf {{justfile_directory()}}/../datalake/bronze/*; \
        rm -rf {{justfile_directory()}}/../datalake/silver/*; \
        rm -rf {{justfile_directory()}}/../datalake/gold/*; \
        rm -rf {{justfile_directory()}}/../datalake/checkpoints/*; \
        echo "[OK] All data cleaned"; \
    fi

# ============================================================================
# ATLAS SCHEMA MIGRATION
# ============================================================================

schema-migrate ENV="local":
    @echo "[ATLAS] Applying migrations (env={{ENV}})"
    atlas migrate apply --env {{ENV}} --dir file://{{justfile_directory()}}/../migrations

schema-lint:
    @echo "[ATLAS] Linting schema"
    atlas migrate lint --env local --latest 1

schema-hash:
    @echo "[ATLAS] Generating migration hash"
    atlas migrate hash --dir file://{{justfile_directory()}}/../migrations

schema-status:
    @echo "[ATLAS] Migration status"
    atlas migrate status --env local
