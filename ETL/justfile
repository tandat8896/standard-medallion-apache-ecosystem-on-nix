shell:
    pyspark --master spark://127.0.0.1:7077 --jars $SPARK_KAFKA_JARS --conf spark.executor.extraClassPath=$SPARK_KAFKA_JARS --conf spark.driver.extraClassPath=$SPARK_KAFKA_JARS --conf spark.jars=$SPARK_KAFKA_JARS --conf spark.executor.userClassPathFirst=true --conf spark.driver.userClassPathFirst=true

run-silver-events DATE:
    @echo "[ETL] Running Bronze → Silver for domain=events (date={{DATE}})"
    PROCESSING_DATE={{DATE}} spark-submit \
        --master spark://127.0.0.1:7077 \
        --conf spark.sql.shuffle.partitions=8 \
        --conf spark.sql.parquet.compression.codec=snappy \
        {{justfile_directory()}}/../scripts/spark_bronze_to_silver_events.py

run-silver-transactions DATE:
    @echo "[ETL] Running Bronze → Silver for domain=transactions (date={{DATE}})"
    PROCESSING_DATE={{DATE}} spark-submit \
        --master spark://127.0.0.1:7077 \
        --conf spark.sql.shuffle.partitions=8 \
        --conf spark.sql.parquet.compression.codec=snappy \
        {{justfile_directory()}}/../scripts/spark_bronze_to_silver_transactions.py

run-silver-customers DATE:
    @echo "[ETL] Running Bronze → Silver for domain=customers (date={{DATE}})"
    PROCESSING_DATE={{DATE}} spark-submit \
        --master spark://127.0.0.1:7077 \
        --conf spark.sql.shuffle.partitions=8 \
        --conf spark.sql.parquet.compression.codec=snappy \
        {{justfile_directory()}}/../scripts/spark_bronze_to_silver_customers.py

run-silver-inventory DATE:
    @echo "[ETL] Running Bronze → Silver for domain=inventory (date={{DATE}})"
    PROCESSING_DATE={{DATE}} spark-submit \
        --master spark://127.0.0.1:7077 \
        --conf spark.sql.shuffle.partitions=8 \
        --conf spark.sql.parquet.compression.codec=snappy \
        {{justfile_directory()}}/../scripts/spark_bronze_to_silver_inventory.py

run-all-silver DATE:
    @echo "[ETL] Running ALL Bronze → Silver jobs for date={{DATE}}"
    just run-silver-events {{DATE}}
    just run-silver-transactions {{DATE}}
    just run-silver-customers {{DATE}}
    just run-silver-inventory {{DATE}}

