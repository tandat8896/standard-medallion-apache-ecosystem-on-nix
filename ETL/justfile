# ============================================================================
# SERVICE MANAGEMENT - Individual Services
# ============================================================================

start-kdc:
    @echo "🔐 Đang khởi động KDC..."
    @if pgrep -f krb5kdc > /dev/null; then \
        echo "   ✅ KDC already running"; \
    else \
        krb5kdc -n -r ETL.LOCAL -d infrastructure/kerberos-data/data/principal -p 8888 > infrastructure/kerberos-data/logs/krb5kdc.log 2>&1 & \
        sleep 1; \
        echo "   ✅ KDC started :8888"; \
    fi

stop-kdc:
    @echo "Đang dẹp tiệm KDC..."
    -pkill -f krb5kdc
    @echo "Đã tắt KDC."

start-zookeeper:
    @echo "📊 Đang khởi động ZooKeeper với Kerberos..."
    @export SERVER_JVMFLAGS="-Djava.security.auth.login.config={{justfile_directory()}}/infrastructure/zookeeper-data/conf/zk_jaas.conf -Djava.security.krb5.conf={{justfile_directory()}}/infrastructure/kerberos-data/conf/krb5.conf" && \
    zkServer.sh start
    @echo "   ✅ ZooKeeper started :2181"

stop-zookeeper:
    @echo "Đang dẹp tiệm ZooKeeper..."
    zkServer.sh stop
    @echo "Đã tắt ZooKeeper."

start-kafka:
    @echo "📨 Đang khởi động Kafka..."
    @if pgrep -f "kafka.Kafka" > /dev/null; then \
        echo "   ✅ Kafka already running"; \
    else \
        kafka-server-start.sh infrastructure/.config/server-1.properties > infrastructure/kafka-data/broker-1.log 2>&1 & \
        kafka-server-start.sh infrastructure/.config/server-2.properties > infrastructure/kafka-data/broker-2.log 2>&1 & \
        sleep 5; \
        echo "   ✅ Kafka started :9092 (2 brokers)"; \
    fi

stop-kafka:
    @echo "Đang dẹp tiệm Kafka..."
    -kafka-server-stop.sh
    sleep 3
    -pkill -f kafka-server-start.sh
    @echo "Đã tắt sạch Kafka."

start-flink:
    @echo "🌊 Đang khởi động Flink với Kerberos..."
    @export FLINK_ENV_JAVA_OPTS="-Djava.security.auth.login.config={{justfile_directory()}}/infrastructure/flink-data/conf/flink_jaas.conf -Djava.security.krb5.conf={{justfile_directory()}}/infrastructure/kerberos-data/conf/krb5.conf" && \
    WEBUIPORT=8081 start-cluster.sh
    @echo "   ✅ Flink started :8081"

stop-flink:
    @echo "Đang dẹp tiệm Flink..."
    stop-cluster.sh
    @echo "Đã tắt Flink."

start-spark:
    @echo "⚡ Đang khởi động Spark..."
    @mkdir -p infrastructure/spark-data
    @if pgrep -f "org.apache.spark.deploy.master.Master" > /dev/null; then \
        echo "   ✅ Spark already running"; \
        echo "   📊 Master UI: http://127.0.0.1:8181"; \
        echo "   📊 Worker UI: http://127.0.0.1:8182"; \
    else \
        spark-class org.apache.spark.deploy.master.Master --host 127.0.0.1 --port 7077 --webui-port 8181 > infrastructure/spark-data/spark-master.log 2>&1 & \
        sleep 3; \
        spark-class org.apache.spark.deploy.worker.Worker --webui-port 8182 -d ./infrastructure/spark-data/worker-work spark://127.0.0.1:7077 > infrastructure/spark-data/spark-worker.log 2>&1 & \
        sleep 2; \
        echo "   ✅ Spark started :7077"; \
        echo "   📊 Master UI: http://127.0.0.1:8181"; \
        echo "   📊 Worker UI: http://127.0.0.1:8182"; \
    fi

stop-spark:
    @echo "Đang dẹp tiệm Spark..."
    -pkill -f org.apache.spark.deploy.master.Master
    -pkill -f org.apache.spark.deploy.worker.Worker
    -pkill -f pyspark
    @echo "Đã tắt sạch Spark."

start-postgres:
    @echo "🐘 Đang khởi động PostgreSQL..."
    @mkdir -p infrastructure/postgres-data infrastructure/postgres-logs
    @if [ ! -f infrastructure/postgres-data/PG_VERSION ]; then \
        echo "   Initializing database cluster..."; \
        initdb -D infrastructure/postgres-data; \
    fi
    @if pg_ctl status -D infrastructure/postgres-data > /dev/null 2>&1; then \
        echo "   ✅ PostgreSQL already running"; \
    else \
        pg_ctl -D infrastructure/postgres-data -l infrastructure/postgres-logs/postgres.log start; \
        sleep 2; \
        echo "   ✅ PostgreSQL started :5432"; \
    fi

stop-postgres:
    @echo "Đang dẹp tiệm PostgreSQL..."
    -pg_ctl -D infrastructure/postgres-data stop
    @echo "Đã tắt PostgreSQL."

# ============================================================================
# ORCHESTRATION - Start/Stop All Services
# ============================================================================

start-all:
    @echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    @echo "🚀 Starting ALL services with Kerberos..."
    @echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    @echo ""
    just start-kdc
    sleep 2
    just start-zookeeper
    sleep 3
    just start-kafka
    sleep 3
    just start-flink
    @echo ""
    @echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    @echo "✅ All services started!"
    @echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    @echo "📊 URLs:"
    @echo "   - ZooKeeper: localhost:2181"
    @echo "   - Kafka:     localhost:9092"
    @echo "   - KDC:       localhost:8888 (realm: ETL.LOCAL)"
    @echo "   - Flink UI:  http://localhost:8081"
    @echo ""
    @echo "Next: just submit-flink-job"

stop-all:
    @echo "🛑 Stopping all services..."
    -just stop-flink
    -just stop-kafka
    -just stop-zookeeper
    -just stop-kdc
    -just stop-spark
    -just stop-postgres
    @echo "✅ All services stopped"

restart-all:
    just stop-all
    sleep 5
    just start-all

# ============================================================================
# FLINK JOBS
# ============================================================================

submit-flink-job:
    @echo "📤 Submitting Flink Bronze Ingest Job..."
    flink run -py {{justfile_directory()}}/../scripts/flink_bronze_ingest.py

list-flink-jobs:
    @flink list

cancel-flink-job JOB_ID:
    @echo "Cancelling Flink job {{JOB_ID}}..."
    flink cancel {{JOB_ID}}

cancel-all-flink-jobs:
    @echo "Cancelling all Flink jobs..."
    @flink list 2>&1 | grep -oP "[a-f0-9]{32}" | xargs -I {} flink cancel {} || true

# ============================================================================
# TESTING & VERIFICATION
# ============================================================================

test-kafka-topic TOPIC:
    @echo "📨 Testing Kafka topic: {{TOPIC}}"
    kafka-console-producer.sh --bootstrap-server localhost:9092 --topic {{TOPIC}}

test-all-topics:
    @echo "📨 Sending test messages to all 5 topics..."
    @echo '{"test_id":"1","source":"events.user","timestamp":"'$(date -u +%Y-%m-%dT%H:%M:%S)'Z"}' | kafka-console-producer.sh --bootstrap-server localhost:9092 --topic events.user
    @echo "✅ Sent to events.user"
    @echo '{"test_id":"2","source":"events.txn","timestamp":"'$(date -u +%Y-%m-%dT%H:%M:%S)'Z"}' | kafka-console-producer.sh --bootstrap-server localhost:9092 --topic events.txn
    @echo "✅ Sent to events.txn"
    @echo '{"test_id":"3","source":"events.iot","timestamp":"'$(date -u +%Y-%m-%dT%H:%M:%S)'Z"}' | kafka-console-producer.sh --bootstrap-server localhost:9092 --topic events.iot
    @echo "✅ Sent to events.iot"
    @echo '{"test_id":"4","source":"logs.app","timestamp":"'$(date -u +%Y-%m-%dT%H:%M:%S)'Z"}' | kafka-console-producer.sh --bootstrap-server localhost:9092 --topic logs.app
    @echo "✅ Sent to logs.app"
    @echo '{"test_id":"5","source":"clicks.web","timestamp":"'$(date -u +%Y-%m-%dT%H:%M:%S)'Z"}' | kafka-console-producer.sh --bootstrap-server localhost:9092 --topic clicks.web
    @echo "✅ Sent to clicks.web"
    @echo ""
    @echo "Wait 15 minutes then run: just verify-bronze"

verify-bronze:
    @echo "🔍 Checking Bronze layer data..."
    @echo ""
    @echo "Files written in last 20 minutes:"
    @find {{justfile_directory()}}/../datalake/bronze -name "*.ndjson" -mmin -20 -ls 2>/dev/null || echo "No files found"
    @echo ""
    @echo "In-progress files:"
    @find {{justfile_directory()}}/../datalake/bronze -name "*inprogress*" -mmin -20 -ls 2>/dev/null || echo "No inprogress files"
    @echo ""
    @echo "Record counts by source:"
    @for src in user_events transactions iot_sensors app_logs clickstream; do \
        count=$(find {{justfile_directory()}}/../datalake/bronze/source=$$src -name "*inprogress*" -exec wc -l {} + 2>/dev/null | tail -1 | awk '{print $1}'); \
        echo "  source=$$src: $$count records"; \
    done

kafka-topics:
    @echo "📋 Kafka Topics:"
    kafka-topics.sh --bootstrap-server localhost:9092 --list

kafka-consumer-groups:
    @echo "👥 Kafka Consumer Groups:"
    kafka-consumer-groups.sh --bootstrap-server localhost:9092 --list

# ============================================================================
# SPARK JOBS
# ============================================================================

shell:
    pyspark --master spark://127.0.0.1:7077 --jars $SPARK_KAFKA_JARS --conf spark.executor.extraClassPath=$SPARK_KAFKA_JARS --conf spark.driver.extraClassPath=$SPARK_KAFKA_JARS --conf spark.jars=$SPARK_KAFKA_JARS --conf spark.executor.userClassPathFirst=true --conf spark.driver.userClassPathFirst=true

run-silver-events DATE:
    @echo "🔄 Running Bronze → Silver for domain=events (date={{DATE}})"
    PROCESSING_DATE={{DATE}} spark-submit \
        --master spark://127.0.0.1:7077 \
        --conf spark.sql.shuffle.partitions=8 \
        --conf spark.sql.parquet.compression.codec=snappy \
        {{justfile_directory()}}/../scripts/spark_bronze_to_silver_events.py

run-silver-transactions DATE:
    @echo "🔄 Running Bronze → Silver for domain=transactions (date={{DATE}})"
    PROCESSING_DATE={{DATE}} spark-submit \
        --master spark://127.0.0.1:7077 \
        --conf spark.sql.shuffle.partitions=8 \
        --conf spark.sql.parquet.compression.codec=snappy \
        {{justfile_directory()}}/../scripts/spark_bronze_to_silver_transactions.py

run-silver-customers DATE:
    @echo "🔄 Running Bronze → Silver for domain=customers (date={{DATE}})"
    PROCESSING_DATE={{DATE}} spark-submit \
        --master spark://127.0.0.1:7077 \
        --conf spark.sql.shuffle.partitions=8 \
        --conf spark.sql.parquet.compression.codec=snappy \
        {{justfile_directory()}}/../scripts/spark_bronze_to_silver_customers.py

run-silver-inventory DATE:
    @echo "🔄 Running Bronze → Silver for domain=inventory (date={{DATE}})"
    PROCESSING_DATE={{DATE}} spark-submit \
        --master spark://127.0.0.1:7077 \
        --conf spark.sql.shuffle.partitions=8 \
        --conf spark.sql.parquet.compression.codec=snappy \
        {{justfile_directory()}}/../scripts/spark_bronze_to_silver_inventory.py

run-all-silver DATE:
    @echo "🔄 Running ALL Bronze → Silver jobs for date={{DATE}}"
    just run-silver-events {{DATE}}
    just run-silver-transactions {{DATE}}
    just run-silver-customers {{DATE}}
    just run-silver-inventory {{DATE}}

