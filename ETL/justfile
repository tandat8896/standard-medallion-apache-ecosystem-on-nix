# ============================================================================
# DATABASE
# ============================================================================

postgres-shell:
    psql -h localhost -d etl_analytics

create-databases:
    @echo "🗄️  Creating databases..."
    @createdb -h localhost airflow_metadata 2>/dev/null || echo "airflow_metadata already exists"
    @createdb -h localhost etl_analytics 2>/dev/null || echo "etl_analytics already exists"
    @echo "✅ Databases ready"

# ============================================================================
# STATUS & LOGS
# ============================================================================

status:
    @echo "📊 Service Status:"
    @echo ""
    @if pgrep -f krb5kdc > /dev/null; then echo "KDC:       ✅ RUNNING"; else echo "KDC:       ❌ STOPPED"; fi
    @if pgrep -f QuorumPeerMain > /dev/null; then echo "ZooKeeper: ✅ RUNNING"; else echo "ZooKeeper: ❌ STOPPED"; fi
    @if pgrep -f 'kafka.Kafka' > /dev/null; then echo "Kafka:     ✅ RUNNING"; else echo "Kafka:     ❌ STOPPED"; fi
    @if pgrep -f 'org.apache.flink' > /dev/null; then echo "Flink:     ✅ RUNNING"; else echo "Flink:     ❌ STOPPED"; fi
    @if pgrep -f 'org.apache.spark.deploy.master.Master' > /dev/null; then echo "Spark:     ✅ RUNNING"; else echo "Spark:     ❌ STOPPED"; fi
    @if pg_ctl status -D infrastructure/postgres-data > /dev/null 2>&1; then echo "Postgres:  ✅ RUNNING"; else echo "Postgres:  ❌ STOPPED"; fi

logs SERVICE:
    @tail -50 infrastructure/{{SERVICE}}-data/logs/*.log 2>/dev/null || tail -50 infrastructure/{{SERVICE}}-data/*.log 2>/dev/null

# ============================================================================
# CLEANUP
# ============================================================================

clean-bronze:
    @echo "⚠️  Cleaning Bronze layer..."
    @read -p "Are you sure? [y/N] " -n 1 -r; \
    if [[ $$REPLY =~ ^[Yy]$$ ]]; then \
        rm -rf {{justfile_directory()}}/../datalake/bronze/*; \
        echo "✅ Bronze layer cleaned"; \
    fi

clean-all-data:
    @echo "⚠️  This will delete ALL data (Bronze/Silver/Gold/Checkpoints)"
    @read -p "Are you sure? [y/N] " -n 1 -r; \
    if [[ $$REPLY =~ ^[Yy]$$ ]]; then \
        rm -rf {{justfile_directory()}}/../datalake/bronze/*; \
        rm -rf {{justfile_directory()}}/../datalake/silver/*; \
        rm -rf {{justfile_directory()}}/../datalake/gold/*; \
        rm -rf {{justfile_directory()}}/../datalake/checkpoints/*; \
        echo "✅ All data cleaned"; \
    fi
