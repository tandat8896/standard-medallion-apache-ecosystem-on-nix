        --conf spark.driver.extraClassPath={{justfile_directory()}}/../jars/postgresql-42.7.4.jar \
        --conf spark.executor.extraClassPath={{justfile_directory()}}/../jars/postgresql-42.7.4.jar \
        --conf spark.sql.shuffle.partitions=8 \
