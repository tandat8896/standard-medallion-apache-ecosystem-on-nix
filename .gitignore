/*
.*
!/.gitignore
!/.env.example
!/ETL/
!/flake.nix
!/flake.lock
!/.envrc
!/justfile
!/README.md
!/README-flink.md

# --- 1. SHOW CONFIGS (Mở khóa toàn bộ file cấu hình) ---
!**/conf/
!**/.config/
!**/*.yaml
!**/*.yml
!**/*.conf
!**/*.properties
!**/conf/**/*.sh      # Only allow .sh in conf/ directories (e.g., spark-env.sh)
!**/*.envrc
!**/masters
!**/workers
!**/java.env
!**/zk_jaas.conf
!**/flink-jaas.conf

# --- 2. HIDE LOGS (Chặn tuyệt đối mọi loại log) ---
*.log
**/*.log
*.out
**/*.out
**/logs/*

# --- 3. GITKEEPS (Giữ cấu trúc thư mục trống) ---
!**/.gitkeep

# ========================================================
# EXCLUDE (Chặn dữ liệu thô và bảo mật)
# ========================================================

# Chặn data nặng/database
/ETL/infrastructure/airflow-data/postgres/
/ETL/infrastructure/kafka-data/broker-1/*
/ETL/infrastructure/kafka-data/broker-2/*
/ETL/infrastructure/spark-data/worker-work/
/ETL/infrastructure/flink-data/ha/
/ETL/infrastructure/zookeeper-data/data/

# BẢO MẬT: Chặn Keytabs và KDC Database
/ETL/infrastructure/kerberos-data/data/principal*
/ETL/infrastructure/kerberos-data/data/*.keytab
/ETL/infrastructure/kerberos-data/data/.k5.*

# Môi trường Local & Build artifacts
.env
.direnv/
**/*.pyc
**/__pycache__/
**/.venv/
/LeetCode/Rust/target/
/ETL/infrastructure/kerberos-data/conf/krb5.conf.5.gz


# --- 1.5 DATALAKE STRUCTURE (Mở khóa cấu trúc Medallion) ---
!/datalake/
!/ingest/
!/dead_letter/
!/scripts/

# Nhưng chặn toàn bộ dữ liệu thực tế bên trong (Parquet, CSV, JSON, v.v.)
/datalake/**/*.parquet
/datalake/**/*.ndjson
/datalake/**/*.csv
/datalake/**/*.json
/datalake/checkpoints/**/*
/ingest/raw/**/*
!**/raw/**/.gitkeep

# PostgreSQL data
/ETL/infrastructure/postgres-data/**/*
/ETL/infrastructure/postgres-logs/**/*
!**/postgres-data/.gitkeep
!**/postgres-logs/.gitkeep
