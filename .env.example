# PostgreSQL Connection Strings - Template
#
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in actual passwords in .env
# 3. NEVER commit .env to git!
#
# Connection string format:
# postgres://username:password@host:port/database?sslmode=disable

# ===================================================================
# LOCAL DEVELOPMENT
# ===================================================================
ATLAS_LOCAL_URL=postgres://tandat8896-nix:YOUR_LOCAL_PASSWORD@localhost:5432/etl_analytics?sslmode=disable

# ===================================================================
# STAGING ENVIRONMENT (for GitHub Actions)
# ===================================================================
# Option 1: Use local DB as staging (for testing)
ATLAS_STAGING_URL=postgres://etl_deployer:YOUR_DEPLOYER_PASSWORD@localhost:5432/etl_analytics_staging?sslmode=disable

# Option 2: Real staging server
# ATLAS_STAGING_URL=postgres://etl_deployer:CHANGE_ME@staging-host:5432/etl_analytics?sslmode=require

# ===================================================================
# PRODUCTION ENVIRONMENT (for GitHub Actions)
# ===================================================================
ATLAS_PROD_URL=postgres://etl_deployer:CHANGE_ME@prod-host:5432/etl_analytics?sslmode=require

# ===================================================================
# CACHIX (for Nix binary cache)
# ===================================================================
CACHIX_AUTH_TOKEN=your-cachix-token-here
